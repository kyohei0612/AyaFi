# aya-afi-ver1 シークレット (サンプル)
# このファイルをコピーして `secrets/.env` にリネーム後、値を埋める
# .env.example は git に含めるが、.env は gitignore 対象 (本物の値は .env に入れる)

# --- LLM ---
# Google AI Studio (https://aistudio.google.com/) で発行。Gemini 2.5 Flash 無料枠 1500 req/日。
# LLM_PROVIDER は mock | gemini (未指定時は mock で動作、API キー不要)
LLM_PROVIDER=mock
GEMINI_API_KEY=
# 2 つ目の Google アカウントの Gemini API キー (任意、primary が 503 の時 fallback)
GEMINI_API_KEY_FALLBACK=
# 開発時のみ使用
ANTHROPIC_API_KEY=

# --- アフィリエイト ---
# もしもアフィリエイトの a_id (管理画面で確認)
MOSHIMO_A_ID=
# 楽天 Web Service (新ポータル 2026-) — UUID 形式のアプリ ID
RAKUTEN_APPLICATION_ID=
# 楽天 access key (pk_... で始まる) — アプリ詳細の 👁 アイコンで表示
RAKUTEN_ACCESS_KEY=
# Origin ヘッダ用 — アプリ登録時の「許可されたウェブサイト」と一致させる
RAKUTEN_ORIGIN=https://github.com
# 楽天アフィリエイト ID
RAKUTEN_AFFILIATE_ID=

# --- SNS: Threads ---
# Meta 開発者で Threads アプリ作成後、ユーザーアクセストークン
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# --- SNS: Bluesky ---
BLUESKY_HANDLE=
# App Password (本体 PW とは別、Bluesky 設定画面で発行)
BLUESKY_APP_PASSWORD=

# --- SNS: note ---
# note は自動投稿しない (ペーストのみ) ので、プロファイルパスを指定
# ブラウザに保存済みのログイン状態を playwright に使わせる (v0.2 以降、v0.1 は未使用)
NOTE_USER_DATA_DIR=
